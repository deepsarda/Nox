{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nox",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nox",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nox",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nox",
          "match": "\\b(if|else|while|for|foreach|in|return|yield|break|continue|try|catch|throw|import|as)\\b"
        },
        {
          "name": "storage.type.nox",
          "match": "\\b(int|double|boolean|string|json|void|type|struct)\\b"
        },
        {
          "name": "constant.language.nox",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.nox",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.nox",
          "match": "\\\\."
        },
        {
          "name": "variable.interpolation.nox",
          "match": "\\$\\{[^}]+\\}"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.nox",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.nox",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.class.nox",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.nox",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    }
  },
  "scopeName": "source.nox"
}