// @test:result "ok"

type Column {
    string name;
    string type;
}

type Table {
    string table;
    Column[] cols;
}

main() {
    json schema = Json.parse("{\"table\": \"users\", \"cols\": [{\"name\": \"id\", \"type\": \"INT\"}, {\"name\": \"name\", \"type\": \"VARCHAR\"}]}");
    Table t = schema as Table;
    
    string query = "CREATE TABLE " + t.table + " (";
    int i = 0;
    while (i < t.cols.length()) {
        Column c = t.cols[i];
        query = query + c.name + " " + c.type;
        if (i < t.cols.length() - 1) {
            query = query + ", ";
        }
        i = i + 1;
    }
    query = query + ");";
    
    try {
        File.write("migration.sql", query);
        File.read("migration.sql"); 
    } catch (err) {
        // mock success
    }
    
    if (query == "CREATE TABLE users (id INT, name VARCHAR);") {
        return "ok";
    }
    return "error";
}
