// @test:result "ok"

main() {
    string log = "ERROR 192.168.1.1 Failed\nINFO 10.0.0.1 Started";
    string[] lines = log.split("\n");

    int errCount = 0;
    int infoCount = 0;
    string lastIp = "";

    foreach (string line in lines) {
        if (line.contains("ERROR")) {
            errCount = errCount + 1;
            lastIp = line.split(" ")[1];
        } else if (line.contains("INFO")) {
            infoCount = infoCount + 1;
        }
    }

    json result = Json.parse("{}");
    result.setInt("errors", errCount);
    result.setInt("infos", infoCount);

    if (result.getInt("errors", 0) == 1) {
        if (lastIp == "192.168.1.1") {
            return "ok";
        }
    }
    return "error";
}
