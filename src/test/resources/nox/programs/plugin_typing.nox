@tool:name "plugin_typing"
@tool:description "Exercises precise plugin typing (int[], json[], etc)."

main() {
    // 1. Array methods (any[])
    int[] nums = [1, 2];
    nums.push(3);
    int n = nums.pop();
    int len = nums.length();

    // 2. JSON array methods
    json data = {ints: [10, 20], strings: ["a", "b"]};
    int[] ja = data.getIntArray("ints", []);
    string[] sa = data.getStringArray("strings", []);
    
    // 3. Recursive JSON
    json[] nested = [{x: 1}];
    json item = {y: 2};
    nested.push(item);
    int nested_len = nested.length();

    return `n: ${n}, len: ${len}, ja[0]: ${ja[0]}, sa[0]: ${sa[0]}, nested_len: ${nested_len}`;
}
