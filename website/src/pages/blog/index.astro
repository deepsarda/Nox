---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!doctype html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="description" content="Nox Language Blog & Release Notes" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog | Nox</title>
</head>
<body class="bg-black text-white selection:bg-cyan-500/30 font-sans overflow-x-hidden min-h-screen flex flex-col">
    <Navbar />

    <main class="flex-grow pt-16 pb-24">
        <div class="container mx-auto px-6 max-w-4xl">
            <h1 class="text-5xl font-extrabold mb-4">Blog</h1>
            <p class="text-gray-400 text-xl mb-12">Release notes, tutorials, and community spotlights.</p>
            
            <div class="grid gap-8">
                {sortedPosts.map(post => (
                    <a href={`/blog/${post.id}`} class="group">
                        <div class="bg-[#0a0a0a] rounded-2xl p-8 border border-white/5 group-hover:border-cyan-500/50 transition-all shadow-[0_0_20px_rgba(0,0,0,0)] group-hover:shadow-[0_0_30px_rgba(6,182,212,0.05)] relative overflow-hidden flex flex-col">
                            <div class="absolute right-0 bottom-0 w-48 h-48 bg-cyan-500/5 rounded-full blur-2xl -mr-10 -mb-10 transition-opacity group-hover:opacity-100 opacity-0"></div>
                            
                            <div class="flex items-center gap-4 mb-4">
                                <time datetime={post.data.date.toISOString()} class="text-cyan-400 font-mono text-sm">
                                    {post.data.date.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}
                                </time>
                                <div class="flex gap-2">
                                    {post.data.tags.map(tag => (
                                        <span class="text-[10px] uppercase tracking-wider font-bold px-2 py-1 rounded-full bg-white/5 text-gray-400">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                            
                            <h2 class="text-2xl font-bold mb-3 text-white group-hover:text-cyan-300 transition-colors">{post.data.title}</h2>
                            <p class="text-gray-400 mb-6 flex-grow">{post.data.description}</p>
                            
                            <div class="flex items-center justify-between text-sm pt-4 border-t border-white/5 text-gray-500">
                                <span>{post.data.author}</span>
                                <span class="text-cyan-400 group-hover:translate-x-1 transition-transform">Read more &rarr;</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </main>

    <footer class="bg-black py-8 border-t border-white/10 text-center">
        <p class="text-sm text-gray-600">© 2026 Nox Language Team.</p>
    </footer>
</body>
</html>