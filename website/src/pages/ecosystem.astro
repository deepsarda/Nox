---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

const plugins = [
    {
        name: "IntelliJ IDEA Plugin",
        description: "Official language support for Nox in IntelliJ IDEA and other JetBrains IDEs. Includes syntax highlighting, semantic analysis, and plugin-aware autocompletion.",
        author: "Nox Team",
        tags: ["IDE", "Official"],
        link: "https://github.com/deepsarda/Nox/tree/main/editors/intellij"
    },
    {
        name: "VS Code Extension",
        description: "Official Visual Studio Code extension with TextMate grammars for .nox and .noxc disassembly formats.",
        author: "Nox Team",
        tags: ["IDE", "Official"],
        link: "https://github.com/deepsarda/Nox/tree/main/editors/vscode"
    },
    {
        name: "nox-lsp",
        description: "The native Language Server Protocol implementation for Nox. Connect any LSP-compatible editor (Neovim, Helix, Zed).",
        author: "Nox Team",
        tags: ["Tool", "Official"],
        link: "https://github.com/deepsarda/Nox/tree/main/tools/lsp"
    },
    {
        name: "noxfmt",
        description: "The official code formatter for NSL. Enforces consistent code style with zero configuration.",
        author: "Nox Team",
        tags: ["Tool", "Official"],
        link: "https://github.com/deepsarda/Nox/tree/main/tools/format"
    },
    {
        name: "noxc",
        description: "The core Nox compiler CLI. Compiles NSL source down to the internal bytecode and provides .noxc disassembly output.",
        author: "Nox Team",
        tags: ["Tool", "Official"],
        link: "https://github.com/deepsarda/Nox/tree/main/tools/cli"
    }
];
---

<!doctype html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="description" content="Nox Ecosystem and Plugins" />
    <meta name="viewport" content="width=device-width" />
    <title>Ecosystem | Nox</title>
</head>
<body class="bg-black text-white selection:bg-cyan-500/30 font-sans overflow-x-hidden min-h-screen flex flex-col">
    <Navbar />

    <main class="flex-grow pt-16 pb-24">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="flex justify-between items-end mb-12">
                <div>
                    <h1 class="text-5xl font-extrabold mb-4">Ecosystem</h1>
                    <p class="text-gray-400 text-xl">Official tooling, integrations, and plugins.</p>
                </div>
            </div>
            
            <div class="grid md:grid-cols-2 gap-6">
                {plugins.map(plugin => (
                    <div class="bg-[#0a0a0a] rounded-2xl p-6 border border-white/10 hover:border-cyan-500/50 transition-colors group flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors">{plugin.name}</h3>
                            <div class="flex gap-2">
                                {plugin.tags.map(tag => (
                                    <span class={`text-[10px] uppercase tracking-wider font-bold px-2 py-1 rounded-full ${tag === 'Official' ? 'bg-cyan-500/20 text-cyan-300' : 'bg-gray-800 text-gray-400'}`}>
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                        <p class="text-gray-400 text-sm mb-6 flex-grow">{plugin.description}</p>
                        <div class="flex justify-between items-center text-sm pt-4 border-t border-white/5">
                            <span class="text-gray-500">by {plugin.author}</span>
                            <a href={plugin.link} class="text-cyan-400 hover:text-cyan-300 font-medium">View &rarr;</a>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </main>

    <footer class="bg-black py-8 border-t border-white/10 text-center">
        <p class="text-sm text-gray-600">© 2026 Nox Language Team.</p>
    </footer>
</body>
</html>